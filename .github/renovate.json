{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitTypeAll(chore)"
  ],
  "semanticCommits": "enabled",
  "labels": [
    "dependencies"
  ],
  "git-submodules": {
    "enabled": false
  },
  "gradle": {
    "managerFilePatterns": [
      "/(^|/)build.gradle.kts$/",
      "/(^|/)settings.gradle.kts$/",
      "/(^|/)gradle/libs\\.versions\\.toml$/"
    ]
  },
  "gomod": {
    "managerFilePatterns": [
      "/libcore/go.mod$/"
    ]
  },
  "github-actions": {
    "managerFilePatterns": [
      "/.github/workflows/.*.yml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "semanticCommitType": "ci",
      "addLabels": [
        "github_action"
      ]
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/sagernet/sing-box",
        "github.com/sagernet/gomobile",
        "github.com/dyhkwong/sing-juicity",
        "github.com/xchacha20-poly1305/cazilla",
        "github.com/xchacha20-poly1305/sing-trusttunnel"
      ],
      "enabled": true,
      "postUpdateOptions": [
        "gomodTidy"
      ],
      "addLabels": [
        "go"
      ]
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "addLabels": [
        "java"
      ]
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "matchPackagePrefixes": [
        "com.google.",
        "com.android.",
        "com.android.tools"
      ],
      "groupName": "Google & Android Tools",
      "groupSlug": "google-android-tools"
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "matchPackagePrefixes": [
        "org.jetbrains.kotlin",
        "org.jetbrains.kotlinx"
      ],
      "matchPackageNames": [
        "com.google.devtools.ksp"
      ],
      "groupName": "Kotlin Ecosystem",
      "groupSlug": "kotlin-ecosystem"
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "matchPackagePrefixes": [
        "androidx.work",
        "androidx.datastore",
        "androidx.room",
        "androidx.sqlite"
      ],
      "groupName": "AndroidX Architecture & Data",
      "groupSlug": "androidx-arch"
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "matchPackagePrefixes": [
        "androidx.core",
        "androidx.appcompat",
        "androidx.activity",
        "androidx.browser",
        "androidx.lifecycle",
        "androidx.camera"
      ],
      "groupName": "AndroidX Core & UI",
      "groupSlug": "androidx-core-ui"
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "matchPackagePrefixes": [
        "androidx.compose",
        "org.jetbrains.compose",
        "org.jetbrains.androidx",
        "com.google.accompanist",
        "me.zhanghai.compose.preference",
        "io.github.oikvpqya.compose.fastscroller",
        "io.github.vinceglb"
      ],
      "matchPackageNames": [
        "androidx.activity:activity-compose",
        "androidx.lifecycle:lifecycle-runtime-compose",
        "androidx.lifecycle:lifecycle-viewmodel-compose",
        "androidx.navigation:navigation-compose"
      ],
      "groupName": "Compose Ecosystem",
      "groupSlug": "compose-ecosystem"
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "matchPackageNames": [
        "com.esotericsoftware:kryo",
        "com.jakewharton:process-phoenix",
        "org.ini4j:ini4j"
      ],
      "groupName": "Utility Libraries",
      "groupSlug": "utility-libraries"
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "matchPackagePrefixes": [
        "com.mikepenz"
      ],
      "matchPackageNames": [
        "org.jetbrains.dokka",
        "org.gradle.toolchains.foojay-resolver-convention"
      ],
      "groupName": "Build Plugins & Tooling",
      "groupSlug": "build-plugins-tooling"
    },
    {
      "matchManagers": [
        "gradle"
      ],
      "matchPackagePrefixes": [
        "org.junit"
      ],
      "groupName": "Testing",
      "groupSlug": "testing"
    },
    {
      "matchPackageNames": [
        "com.google.guava:guava"
      ],
      "allowedVersions": "/-android$/"
    }
  ]
}
